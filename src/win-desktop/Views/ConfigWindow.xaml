<Window x:Class="Hope.Desktop.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="Hope · 盼头" Width="1000" MinWidth="1000" MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowActivated="True"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        FontFamily="Microsoft YaHei UI" FontSize="13">
    <Window.Resources>
        <!-- 保留系统默认 DatePicker 外观，仅强制不透明与主题前景色（§5.3.1 需求 3 修订） -->
        <Style TargetType="{x:Type primitives:DatePickerTextBox}">
            <Setter Property="Background" Value="{DynamicResource ControlFillColorDefaultBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <Style TargetType="{x:Type Calendar}">
            <Setter Property="Background" Value="{DynamicResource ApplicationBackgroundBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>
        <!-- 任务编辑区分割线：随 Fluent 主题切换，2px 控制描边色（显眼且与背景对比） -->
        <Style x:Key="TaskEditSeparator" TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="0,14,0,14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="2"
                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                CornerRadius="1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>
    <Grid x:Name="RootGrid" Margin="16,8,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="380" />
            </Grid.ColumnDefinitions>

            <!-- 任务列表 -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="任务列表" FontWeight="Bold" VerticalAlignment="Center" />
                    <ui:Button Grid.Column="1" x:Name="AddTaskButton" Content="添加任务"
                               Appearance="Primary" Icon="{ui:SymbolIcon Add24}"
                               Padding="12,4" Click="OnAddTask" />
                </Grid>
                <ui:Button DockPanel.Dock="Bottom" x:Name="DeleteButton" Content="删除选中任务"
                           HorizontalAlignment="Stretch" Height="32" Margin="0,8,0,0" Click="OnDelete" />
                <ui:DataGrid x:Name="TaskGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          SelectionChanged="OnSelectTask" GridLinesVisibility="Horizontal"
                          Background="{DynamicResource ControlFillColorDefaultBrush}"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="颜色" Width="56" MinWidth="56">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="16" Height="16" CornerRadius="3"
                                            HorizontalAlignment="Center"
                                            Background="{Binding ColorBrush}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="类型" Binding="{Binding TypeLabel}" Width="60" />
                        <DataGridTextColumn Header="截止" Binding="{Binding EndLabel}" Width="120" />
                    </DataGrid.Columns>
                </ui:DataGrid>
            </DockPanel>

            <!-- 右侧：全局设置 / 任务编辑 双 Tab -->
            <TabControl Grid.Column="1" x:Name="MainTabs"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                <!-- 全局设置（默认 Tab） -->
                <TabItem Header="全局设置">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="4,8,8,4">
                        <StackPanel>
                            <TextBlock Text="全局设置" FontWeight="Bold" Margin="0,0,0,8" />

                            <TextBlock Text="刷新间隔（秒，进度条更新频率）" Margin="0,6,0,2" />
                            <ComboBox x:Name="RefreshBox" HorizontalAlignment="Stretch" />

                            <TextBlock Text="进度条高度（px）" Margin="0,12,0,2" />
                            <ComboBox x:Name="BarHeightBox" HorizontalAlignment="Stretch" />

                            <CheckBox x:Name="AutostartCheck" Content="开机自启动" Margin="0,16,0,0" />

                            <CheckBox x:Name="ShowConfigAtRuntimeCheck" Content="运行时显示此窗口"
                                      Margin="0,12,0,0"
                                      ToolTip="开启后，下次启动 Hope 时自动打开本配置窗口（默认仅托盘驻留）" />

                            <ui:Button x:Name="ResetWindowHeightButton" Content="重置窗口高度"
                                       HorizontalAlignment="Stretch" Height="32" Margin="0,12,0,0"
                                       Click="OnResetWindowHeight" />

                            <TextBlock x:Name="SettingsStatus" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,10,0,4" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- 任务编辑 -->
                <TabItem Header="任务编辑" x:Name="TaskTab">
                        <StackPanel x:Name="TaskEditPanel" Margin="4,8,8,4">
                            <TextBlock x:Name="StatusText" Text="新建任务" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Margin="0,0,0,6" TextWrapping="Wrap" />

                            <TextBlock Text="名称" Margin="0,6,0,2" />
                            <ui:TextBox x:Name="NameBox" PlaceholderText="任务名称" />
                            <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                <TextBlock Text="快填：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ui:Button Content="下班" Padding="10,2" Margin="2,0" Click="OnPresetName" />
                                <ui:Button Content="干饭" Padding="10,2" Margin="2,0" Click="OnPresetName" />
                                <ui:Button Content="放假" Padding="10,2" Margin="2,0" Click="OnPresetName" />
                            </StackPanel>

                            <TextBlock Text="颜色 (#RRGGBB)" Margin="0,8,0,2" />
                            <DockPanel>
                                <Border x:Name="ColorPreview" DockPanel.Dock="Right" Width="28" Height="28"
                                        CornerRadius="4" Margin="6,0,0,0" Background="#FF6B35"
                                        Cursor="Hand" MouseLeftButtonUp="OnPickColor"
                                        ToolTip="点击打开系统取色盘选择颜色" />
                                <ui:TextBox x:Name="ColorBox" Text="#FF6B35" TextChanged="OnColorChanged" />
                            </DockPanel>

                            <TextBlock Text="跟随图片 / 动图（可选）" Margin="0,8,0,2" />
                            <DockPanel>
                                <ui:Button DockPanel.Dock="Right" Content="清除" Width="56" Margin="6,0,0,0" Click="OnClearGif" />
                                <ui:Button DockPanel.Dock="Right" Content="选择图片" Width="78" Margin="6,0,0,0" Click="OnBrowseGif" />
                                <ui:TextBox x:Name="GifBox" IsReadOnly="True"
                                            ToolTip="支持任意图片格式；图片挂在进度条下方，跟随该任务进度前沿移动，动图循环播放（超过 15px 自动缩放）" />
                            </DockPanel>

                            <!-- 实时预览：按墙钟 percent 填充 + 挂载图片（§5.3.3 新增 2） -->
                            <TextBlock Text="预览（实时；保存后影响桌面顶栏）" Margin="0,12,0,2"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <Border BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1"
                                    CornerRadius="6" Padding="10" Background="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                                <StackPanel>
                                    <Grid x:Name="PreviewTrack" ClipToBounds="True" HorizontalAlignment="Stretch">
                                        <Border x:Name="PreviewFill" HorizontalAlignment="Left" VerticalAlignment="Stretch"
                                                CornerRadius="1" Background="#FF6B35" Width="0" />
                                    </Grid>
                                    <Canvas x:Name="PreviewImageCanvas" Height="15" Margin="0,4,0,0"
                                            HorizontalAlignment="Stretch" />
                                    <TextBlock x:Name="PreviewStatus" Margin="0,6,0,0" FontSize="12"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </Border>

                            <TextBlock Text="类型" Margin="0,12,0,2" />
                            <ComboBox x:Name="TypeBox" SelectionChanged="OnTypeChanged" HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="定时任务（含开始时间）" Tag="scheduled" IsSelected="True" />
                                <ComboBoxItem Content="即时任务（仅截止时间）" Tag="instant" />
                            </ComboBox>

                            <Separator Style="{StaticResource TaskEditSeparator}" />

                            <StackPanel x:Name="StartPanel">
                                <TextBlock Text="开始日期" Margin="0,8,0,2" />
                                <DatePicker x:Name="StartDatePicker" HorizontalAlignment="Stretch" />
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="快填：" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <ui:Button Content="今天" Tag="StartDate:Today" Padding="8,2" Margin="2,0" Click="OnDateQuickFill" />
                                    <ui:Button Content="明天" Tag="StartDate:Tomorrow" Padding="8,2" Margin="2,0" Click="OnDateQuickFill" />
                                    <ui:Button Content="后天" Tag="StartDate:DayAfter" Padding="8,2" Margin="2,0" Click="OnDateQuickFill" />
                                    <ui:Button Content="一周后" Tag="StartDate:Week" Padding="8,2" Margin="2,0" Click="OnDateQuickFill" />
                                    <ui:Button Content="一月后" Tag="StartDate:Month" Padding="8,2" Margin="2,0" Click="OnDateQuickFill" />
                                </StackPanel>
                                <TextBlock Text="开始时间（时 : 分）" Margin="0,6,0,2" />
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="StartHourBox" Width="78" />
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0,6,0" FontWeight="Bold" />
                                    <ComboBox x:Name="StartMinuteBox" Width="78" />
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                    <TextBlock Text="快填：" VerticalAlignment="Center"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    <ui:Button Content="现在" Tag="StartTime:Now" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                                    <ui:Button Content="+0.5H" Tag="StartTime:H0.5" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                                    <ui:Button Content="+1H" Tag="StartTime:H1" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                                    <ui:Button Content="+2H" Tag="StartTime:H2" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                                    <ui:Button Content="+8H" Tag="StartTime:H8" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                                    <ui:Button Content="+12H" Tag="StartTime:H12" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                                </StackPanel>
                            </StackPanel>

                            <Separator Style="{StaticResource TaskEditSeparator}" />

                            <TextBlock Text="截止日期" Margin="0,0,0,2" />
                            <DatePicker x:Name="EndDatePicker" HorizontalAlignment="Stretch" />
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="快填：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ui:Button Content="今天" Tag="EndDate:Today" Padding="8,2" Margin="2,0" Click="OnDateQuickFill" />
                                <ui:Button Content="明天" Tag="EndDate:Tomorrow" Padding="8,2" Margin="2,0" Click="OnDateQuickFill" />
                                <ui:Button Content="后天" Tag="EndDate:DayAfter" Padding="8,2" Margin="2,0" Click="OnDateQuickFill" />
                                <ui:Button Content="一周后" Tag="EndDate:Week" Padding="8,2" Margin="2,0" Click="OnDateQuickFill" />
                                <ui:Button Content="一月后" Tag="EndDate:Month" Padding="8,2" Margin="2,0" Click="OnDateQuickFill" />
                            </StackPanel>
                            <TextBlock Text="截止时间（时 : 分）" Margin="0,6,0,2" />
                            <StackPanel Orientation="Horizontal">
                                <ComboBox x:Name="EndHourBox" Width="78" />
                                <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0,6,0" FontWeight="Bold" />
                                <ComboBox x:Name="EndMinuteBox" Width="78" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                <TextBlock Text="快填：" VerticalAlignment="Center"
                                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <ui:Button Content="现在" Tag="EndTime:Now" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                                <ui:Button Content="+0.5H" Tag="EndTime:H0.5" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                                <ui:Button Content="+1H" Tag="EndTime:H1" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                                <ui:Button Content="+2H" Tag="EndTime:H2" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                                <ui:Button Content="+8H" Tag="EndTime:H8" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                                <ui:Button Content="+12H" Tag="EndTime:H12" Padding="8,2" Margin="2,0" Click="OnTimeQuickFill" />
                            </StackPanel>

                            <ui:Button x:Name="SaveButton" Content="保存任务" Appearance="Primary"
                                       HorizontalAlignment="Stretch" Height="34" Margin="0,14,0,0" Click="OnSave" />
                            <ui:Button x:Name="NewButton" Content="清空（新建）"
                                       HorizontalAlignment="Stretch" Height="30" Margin="0,6,0,0" Click="OnNew" />
                        </StackPanel>
                </TabItem>
            </TabControl>
    </Grid>
</Window>
