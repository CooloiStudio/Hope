<ui:FluentWindow x:Class="Hope.Desktop.Views.ConfigWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        xmlns:converters="clr-namespace:Hope.Desktop.Converters"
        Title="Hope · 盼头" Width="1010" MinWidth="1010" MinHeight="400"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        ShowActivated="True"
        ExtendsContentIntoTitleBar="True"
        WindowBackdropType="None"
        WindowCornerPreference="Round"
        Background="{DynamicResource ApplicationBackgroundBrush}"
        Foreground="{DynamicResource TextFillColorPrimaryBrush}"
        FontFamily="Microsoft YaHei UI" FontSize="13">
    <Window.Resources>
        <!-- DatePicker / Calendar 沿用 WPF-UI ControlsDictionary 的 Fluent 隐式样式（深色圆角 + Fluent 日历）。
             日历弹窗背景键 CalendarViewBackground 默认取 ControlFillColorInputActive（暗色下 #B31E1E1E，半透明），
             独立弹窗中会透出桌面；此处仅覆盖该键为不透明表面色，不动其它控件背景。 -->
        <SolidColorBrush x:Key="CalendarViewBackground" Color="{DynamicResource SolidBackgroundFillColorBase}" />
        <!-- 表单字段标签：定宽左列，使所有行的控件竖直对齐（紧凑单行布局） -->
        <Style x:Key="FieldLabel" TargetType="{x:Type TextBlock}">
            <Setter Property="Width" Value="56" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="TextAlignment" Value="Right" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="TextWrapping" Value="NoWrap" />
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
        </Style>
        <!-- 快填行的次级标签：与字段标签同宽，按钮列对齐 -->
        <Style x:Key="QuickFillLabel" TargetType="{x:Type TextBlock}" BasedOn="{StaticResource FieldLabel}">
            <Setter Property="Foreground" Value="{DynamicResource TextFillColorSecondaryBrush}" />
        </Style>
        <!-- 任务编辑区分割线：随 Fluent 主题切换，2px 控制描边色（显眼且与背景对比） -->
        <Style x:Key="TaskEditSeparator" TargetType="{x:Type Separator}">
            <Setter Property="Margin" Value="0,14,0,14" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Separator}">
                        <Border Height="2"
                                Background="{DynamicResource ControlStrokeColorDefaultBrush}"
                                CornerRadius="1" />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <!-- 布尔值与 Visibility 转换器：用于列表中根据完成状态显隐按钮/文本。 -->
        <converters:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter" />
        <converters:BoolToVisibilityConverter x:Key="InvertedBoolToVisibilityConverter" Inverted="True" />
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <ui:TitleBar x:Name="AppTitleBar" Grid.Row="0" Title="Hope · 盼头">
            <ui:TitleBar.Icon>
                <ui:SymbolIcon Symbol="Timer24" />
            </ui:TitleBar.Icon>
        </ui:TitleBar>

        <Grid x:Name="RootGrid" Grid.Row="1" Margin="16,8,16,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="390" />
            </Grid.ColumnDefinitions>

            <!-- 任务列表 -->
            <DockPanel Grid.Column="0" Margin="0,0,12,0">
                <Grid DockPanel.Dock="Top" Margin="0,0,0,6">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <TextBlock Text="任务列表" FontWeight="Bold" VerticalAlignment="Center" />
                    <ui:Button Grid.Column="1" x:Name="AddTaskButton" Content="添加任务"
                               Appearance="Primary" Icon="{ui:SymbolIcon Add24}"
                               Padding="12,4" Click="OnAddTask" />
                </Grid>
                <ui:Button DockPanel.Dock="Bottom" x:Name="DeleteButton" Content="删除选中任务"
                           HorizontalAlignment="Stretch" Height="32" Margin="0,8,0,0" Click="OnDelete" />
                <ui:DataGrid x:Name="TaskGrid" AutoGenerateColumns="False" IsReadOnly="True"
                          SelectionMode="Single" HeadersVisibility="Column"
                          SelectionChanged="OnSelectTask" GridLinesVisibility="Horizontal"
                          Background="{DynamicResource ControlFillColorDefaultBrush}"
                          Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                          BorderBrush="{DynamicResource ControlStrokeColorDefaultBrush}">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="颜色" Width="56" MinWidth="56">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Border Width="16" Height="16" CornerRadius="3"
                                            HorizontalAlignment="Center"
                                            Background="{Binding ColorBrush}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="名称" Binding="{Binding Name}" Width="*" />
                        <DataGridTextColumn Header="类型" Binding="{Binding TypeLabel}" Width="60" />
                        <DataGridTextColumn Header="截止" Binding="{Binding EndLabel}" Width="120" />
                        <DataGridTemplateColumn Header="操作" Width="72" MinWidth="72">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <ui:Button Content="完成" Padding="6,2" FontSize="12"
                                                   HorizontalAlignment="Center"
                                                   Tag="{Binding Id}"
                                                   Click="OnCompleteTask"
                                                   Visibility="{Binding Completed, Converter={StaticResource InvertedBoolToVisibilityConverter}}" />
                                        <TextBlock Text="已完成" FontSize="12"
                                                   VerticalAlignment="Center" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                                   Visibility="{Binding Completed, Converter={StaticResource BoolToVisibilityConverter}}" />
                                    </Grid>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </ui:DataGrid>
            </DockPanel>

            <!-- 右侧：全局设置 / 任务编辑 双 Tab -->
            <TabControl Grid.Column="1" x:Name="MainTabs"
                        Background="{DynamicResource ApplicationBackgroundBrush}"
                        Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                <!-- 全局设置（默认 Tab） -->
                <TabItem Header="全局设置">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="4,8,8,4">
                        <StackPanel>
                            <TextBlock Text="全局设置" FontWeight="Bold" Margin="0,0,0,8" />

                            <!-- 进度条设置分组 -->
                            <Grid Margin="0,6,0,8">
                                <Border Height="1" VerticalAlignment="Center" Background="{DynamicResource ControlStrokeColorDefaultBrush}" />
                                <TextBlock Text="进度条设置" HorizontalAlignment="Center"
                                           Background="{DynamicResource ApplicationBackgroundBrush}"
                                           Padding="8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12" />
                            </Grid>

                            <TextBlock Text="粗细（px）" Margin="0,6,0,2" />
                            <DockPanel LastChildFill="True">
                                <TextBlock x:Name="BarHeightValueText" DockPanel.Dock="Right"
                                           Width="20" TextAlignment="Center" VerticalAlignment="Center"
                                           Margin="8,0,0,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Slider x:Name="BarHeightBox" Minimum="1" Maximum="10" TickFrequency="1"
                                        IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                            </DockPanel>

                            <TextBlock Text="图片最大高度（px）" Margin="0,12,0,2" />
                            <DockPanel LastChildFill="True">
                                <TextBlock x:Name="ImageMaxHeightValueText" DockPanel.Dock="Right"
                                           Width="24" TextAlignment="Center" VerticalAlignment="Center"
                                           Margin="8,0,0,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                <Slider x:Name="ImageMaxHeightBox" Minimum="15" Maximum="30" TickFrequency="1"
                                        IsSnapToTickEnabled="True" VerticalAlignment="Center"
                                        ToolTip="所有任务图片统一的最大高度，超出按比例缩放" />
                            </DockPanel>

                            <TextBlock Text="起始位置" Margin="0,12,0,2" />
                            <ComboBox x:Name="BarPositionBox" HorizontalAlignment="Stretch"
                                      SelectionChanged="OnBarPositionChanged"
                                      ToolTip="进度条在屏幕上的位置">
                                <ComboBoxItem Content="屏幕顶边" Tag="top" IsSelected="True" />
                                <ComboBoxItem Content="屏幕底边" Tag="bottom" />
                                <ComboBoxItem Content="屏幕左边" Tag="left" />
                                <ComboBoxItem Content="屏幕右边" Tag="right" />
                            </ComboBox>

                            <CheckBox x:Name="ShowAdvancedSettingsCheck" Content="显示高级设置"
                                      Margin="0,12,0,0"
                                      Checked="OnShowAdvancedSettingsChanged" Unchecked="OnShowAdvancedSettingsChanged"
                                      ToolTip="勾选后展开高级选项" />

                            <StackPanel x:Name="AdvancedOptionsPanel" Margin="0,4,0,0" Visibility="Collapsed">
                                <TextBlock Text="前进方向" Margin="0,6,0,2" />
                                <ComboBox x:Name="BarDirectionBox" HorizontalAlignment="Stretch"
                                          SelectionChanged="OnBarDirectionChanged"
                                          ToolTip="根据位置自动选择默认方向；可手动覆盖">
                                    <ComboBoxItem Content="默认" Tag="" IsSelected="True" />
                                    <ComboBoxItem Content="从左到右" Tag="forward" />
                                    <ComboBoxItem Content="从右到左" Tag="reverse" />
                                    <ComboBoxItem Content="从上到下" Tag="forward" />
                                    <ComboBoxItem Content="从下到上" Tag="reverse" />
                                </ComboBox>

                                <TextBlock Text="刷新间隔（秒，进度条更新频率）" Margin="0,12,0,2" />
                                <DockPanel LastChildFill="True">
                                    <TextBlock x:Name="RefreshValueText" DockPanel.Dock="Right"
                                               Width="20" TextAlignment="Center" VerticalAlignment="Center"
                                               Margin="8,0,0,0" Foreground="{DynamicResource TextFillColorPrimaryBrush}" />
                                    <Slider x:Name="RefreshBox" Minimum="1" Maximum="10" TickFrequency="1"
                                            IsSnapToTickEnabled="True" VerticalAlignment="Center" />
                                </DockPanel>

                                <CheckBox x:Name="AllFourCheck" Content="我全都要（四边环绕）"
                                          Margin="0,12,0,0"
                                          Checked="OnAllFourChanged" Unchecked="OnAllFourChanged"
                                          ToolTip="从当前位置出发，沿当前方向环绕屏幕四边" />

                                <CheckBox x:Name="AdvancedPositionCheck" Content="允许为单个任务指定展示位置"
                                          Margin="0,12,0,0"
                                          ToolTip="开启后，任务编辑中会出现「展示位置」选项" />
                            </StackPanel>

                            <Grid Margin="0,6,0,8">
                                <Border Height="1" VerticalAlignment="Center" Background="{DynamicResource ControlStrokeColorDefaultBrush}" />
                                <TextBlock Text="任务提醒设置" HorizontalAlignment="Center"
                                           Background="{DynamicResource ApplicationBackgroundBrush}"
                                           Padding="8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12" />
                            </Grid>

                            <TextBlock Text="到期提醒效果（默认自动显示，可叠加勾选）" Margin="0,12,0,2"
                                       TextWrapping="Wrap" />
                            <CheckBox x:Name="GlobalBlinkCheck" Content="闪烁提醒"
                                      Margin="0,4,0,0"
                                      ToolTip="到期后顶栏柔和闪烁，直到用户查看" />
                            <CheckBox x:Name="GlobalCelebrateCheck" Content="全屏庆祝"
                                      Margin="0,6,0,0"
                                      ToolTip="到期时四边同步闪烁庆祝" />
                            <CheckBox x:Name="GlobalNotifyCheck" Content="系统通知"
                                      Margin="0,6,0,0"
                                      ToolTip="到期时弹出一次系统气球通知" />

                            <Grid Margin="0,6,0,8">
                                <Border Height="1" VerticalAlignment="Center" Background="{DynamicResource ControlStrokeColorDefaultBrush}" />
                                <TextBlock Text="应用启动设置" HorizontalAlignment="Center"
                                           Background="{DynamicResource ApplicationBackgroundBrush}"
                                           Padding="8,0" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                           FontSize="12" />
                            </Grid>

                            <CheckBox x:Name="AutostartCheck" Content="开机自启动" Margin="0,16,0,0" />

                            <CheckBox x:Name="ShowConfigAtRuntimeCheck" Content="运行时显示此窗口"
                                      Margin="0,12,0,0"
                                      ToolTip="开启后，下次启动 Hope 时自动打开本配置窗口（默认仅托盘驻留）" />

                            <ui:Button x:Name="ResetWindowHeightButton" Content="重置窗口高度"
                                       HorizontalAlignment="Stretch" Height="32" Margin="0,12,0,0"
                                       Click="OnResetWindowHeight" />

                            <TextBlock x:Name="SettingsStatus" Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Margin="0,10,0,4" TextWrapping="Wrap" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <!-- 任务编辑 -->
                <TabItem Header="任务编辑" x:Name="TaskTab">
                        <StackPanel x:Name="TaskEditPanel" Margin="4,8,8,4">
                            <TextBlock x:Name="StatusText" Text="新建任务" FontWeight="Bold"
                                       Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                                       Margin="0,0,0,6" TextWrapping="Wrap" />

                            <!-- 名称 -->
                            <DockPanel Margin="0,3,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="名称" />
                                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Margin="6,0,0,0">
                                    <ui:Button Content="下班" Padding="8,2" Margin="2,0" Click="OnPresetName" />
                                    <ui:Button Content="干饭" Padding="8,2" Margin="2,0" Click="OnPresetName" />
                                    <ui:Button Content="放假" Padding="8,2" Margin="2,0" Click="OnPresetName" />
                                </StackPanel>
                                <ui:TextBox x:Name="NameBox" PlaceholderText="任务名称" />
                            </DockPanel>

                            <!-- 颜色 -->
                            <DockPanel Margin="0,6,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="颜色" />
                                <Border x:Name="ColorPreview" DockPanel.Dock="Right" Width="28" Height="28"
                                        CornerRadius="4" Margin="6,0,0,0" Background="#FF6B35"
                                        Cursor="Hand" MouseLeftButtonUp="OnPickColor"
                                        ToolTip="点击打开系统取色盘选择颜色" />
                                <ui:TextBox x:Name="ColorBox" Text="#FF6B35" TextChanged="OnColorChanged" />
                            </DockPanel>

                            <!-- 展示位置（仅在高级设置中开启后显示） -->
                            <DockPanel x:Name="TaskPositionRow" Margin="0,6,0,0" Visibility="Collapsed">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="展示位置" />
                                <ComboBox x:Name="TaskPositionBox" HorizontalAlignment="Stretch"
                                          ToolTip="空表示沿用全局位置">
                                    <ComboBoxItem Content="默认（沿用全局）" Tag="" IsSelected="True" />
                                    <ComboBoxItem Content="屏幕顶边" Tag="top" />
                                    <ComboBoxItem Content="屏幕底边" Tag="bottom" />
                                    <ComboBoxItem Content="屏幕左边" Tag="left" />
                                    <ComboBoxItem Content="屏幕右边" Tag="right" />
                                </ComboBox>
                            </DockPanel>

                            <!-- 图片 / 动图 -->
                            <DockPanel Margin="0,6,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="图片" />
                                <ui:Button DockPanel.Dock="Right" Content="清除" Width="52" Margin="6,0,0,0" Click="OnClearGif" />
                                <ui:Button DockPanel.Dock="Right" Content="选择" Width="52" Margin="6,0,0,0" Click="OnBrowseGif" />
                                <ui:TextBox x:Name="GifBox" IsReadOnly="True"
                                            PlaceholderText="（可拖放图片到此）"
                                            AllowDrop="True" PreviewDragOver="OnGifDragOver" Drop="OnGifDrop"
                                            ToolTip="支持任意图片格式；可直接拖放图片文件到此。图片挂在进度条下方，跟随该任务进度前沿移动，动图循环播放（超过 15px 自动缩放）" />
                            </DockPanel>

                            <Separator Style="{StaticResource TaskEditSeparator}" />

                            <!-- 类型 -->
                            <DockPanel>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="类型" />
                                <ComboBox x:Name="TypeBox" SelectionChanged="OnTypeChanged" HorizontalAlignment="Stretch">
                                    <ComboBoxItem Content="定时任务（含开始时间）" Tag="scheduled" IsSelected="True" />
                                    <ComboBoxItem Content="即时任务（仅截止时间）" Tag="instant" />
                                </ComboBox>
                            </DockPanel>

                            <!-- 循环（仅定时任务；即时任务隐藏）。开始/截止的时分定义每个发生日窗口，开始日期为锚点 -->
                            <StackPanel x:Name="RecurPanel">
                                <DockPanel Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="循环" />
                                    <ComboBox x:Name="RecurModeBox" HorizontalAlignment="Stretch"
                                              SelectionChanged="OnRecurModeChanged"
                                              ToolTip="循环任务：每个发生日重复「开始时间~截止时间」窗口（支持跨午夜）">
                                        <ComboBoxItem Content="不循环（单次）" Tag="" IsSelected="True" />
                                        <ComboBoxItem Content="每天" Tag="daily" />
                                        <ComboBoxItem Content="间隔若干天循环" Tag="everyN" />
                                        <ComboBoxItem Content="按星期" Tag="weekly" />
                                    </ComboBox>
                                </DockPanel>
                                <DockPanel x:Name="RecurIntervalRow" Margin="0,4,0,0" Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource QuickFillLabel}" Text="间隔" />
                                    <ui:TextBox x:Name="RecurIntervalBox" DockPanel.Dock="Left" Width="80"
                                                MaxLength="3" PlaceholderText="2" TextChanged="OnRecurIntervalChanged" />
                                    <TextBlock Text="天循环（2~800）" VerticalAlignment="Center" Margin="8,0,0,0"
                                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                </DockPanel>
                                <DockPanel x:Name="RecurWeekRow" Margin="0,4,0,0" Visibility="Collapsed">
                                    <TextBlock Style="{StaticResource QuickFillLabel}" Text="星期" VerticalAlignment="Top" />
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <CheckBox x:Name="ChkMon" Content="一" Tag="1" MinWidth="0" Padding="6,0,0,0" Margin="0,0,5,0" />
                                            <CheckBox x:Name="ChkTue" Content="二" Tag="2" MinWidth="0" Padding="6,0,0,0" Margin="0,0,5,0" />
                                            <CheckBox x:Name="ChkWed" Content="三" Tag="3" MinWidth="0" Padding="6,0,0,0" Margin="0,0,5,0" />
                                            <CheckBox x:Name="ChkThu" Content="四" Tag="4" MinWidth="0" Padding="6,0,0,0" Margin="0,0,5,0" />
                                            <CheckBox x:Name="ChkFri" Content="五" Tag="5" MinWidth="0" Padding="6,0,0,0" Margin="0,0,5,0" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                            <CheckBox x:Name="ChkSat" Content="六" Tag="6" MinWidth="0" Padding="6,0,0,0" Margin="0,0,5,0" />
                                            <CheckBox x:Name="ChkSun" Content="日" Tag="0" MinWidth="0" Padding="6,0,0,0" Margin="0,0,5,0" />
                                        </StackPanel>
                                    </StackPanel>
                                </DockPanel>
                            </StackPanel>

                            <!-- 到期提醒：默认自动显示；勾「使用全局默认」沿用全局，否则可叠加勾选 -->
                            <DockPanel Margin="0,6,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="到期提醒" VerticalAlignment="Center" />
                                <CheckBox x:Name="TaskUseGlobalCheck" Content="使用全局默认"
                                          VerticalAlignment="Center"
                                          Checked="OnTaskUseGlobalChanged" Unchecked="OnTaskUseGlobalChanged"
                                          ToolTip="勾选则本任务沿用全局到期提醒；取消后可单独叠加勾选下列效果" />
                            </DockPanel>
                            <StackPanel x:Name="TaskBehaviorPanel" Orientation="Horizontal" Margin="56,4,0,0">
                                <CheckBox x:Name="TaskBlinkCheck" Content="闪烁提醒" Margin="0,0,12,0"
                                          ToolTip="到期后顶栏柔和闪烁，直到用户查看" />
                                <CheckBox x:Name="TaskCelebrateCheck" Content="全屏庆祝" Margin="0,0,12,0"
                                          ToolTip="到期时四边同步闪烁庆祝" />
                                <CheckBox x:Name="TaskNotifyCheck" Content="系统通知"
                                          ToolTip="到期时弹出一次系统气球通知" />
                            </StackPanel>

                            <StackPanel x:Name="StartPanel">
                                <Separator Style="{StaticResource TaskEditSeparator}" />
                                <!-- 开始日期 -->
                                <DockPanel>
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="开始日期" />
                                    <DatePicker x:Name="StartDatePicker" HorizontalAlignment="Stretch" />
                                </DockPanel>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock Style="{StaticResource QuickFillLabel}" Text="快填" />
                                    <WrapPanel>
                                        <ui:Button Content="今天" Tag="StartDate:Today" Padding="6,2" Margin="2,0,2,2" Click="OnDateQuickFill" />
                                        <ui:Button Content="明天" Tag="StartDate:Tomorrow" Padding="6,2" Margin="2,0,2,2" Click="OnDateQuickFill" />
                                        <ui:Button Content="后天" Tag="StartDate:DayAfter" Padding="6,2" Margin="2,0,2,2" Click="OnDateQuickFill" />
                                        <ui:Button Content="一周后" Tag="StartDate:Week" Padding="6,2" Margin="2,0,2,2" Click="OnDateQuickFill" />
                                        <ui:Button Content="一月后" Tag="StartDate:Month" Padding="6,2" Margin="2,0,2,2" Click="OnDateQuickFill" />
                                    </WrapPanel>
                                </DockPanel>
                                <!-- 开始时间（时 : 分） -->
                                <DockPanel Margin="0,6,0,0">
                                    <TextBlock Style="{StaticResource FieldLabel}" Text="开始时间" />
                                    <StackPanel Orientation="Horizontal">
                                        <ComboBox x:Name="StartHourBox" Width="78" />
                                        <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0,6,0" FontWeight="Bold" />
                                        <ComboBox x:Name="StartMinuteBox" Width="78" />
                                    </StackPanel>
                                </DockPanel>
                                <DockPanel Margin="0,4,0,0">
                                    <TextBlock Style="{StaticResource QuickFillLabel}" Text="快填" />
                                    <WrapPanel>
                                        <ui:Button Content="现在" Tag="StartTime:Now" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                        <ui:Button Content="+0.5H" Tag="StartTime:H0.5" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                        <ui:Button Content="+1H" Tag="StartTime:H1" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                        <ui:Button Content="+2H" Tag="StartTime:H2" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                        <ui:Button Content="+8H" Tag="StartTime:H8" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                        <ui:Button Content="+12H" Tag="StartTime:H12" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                    </WrapPanel>
                                </DockPanel>
                            </StackPanel>

                            <Separator Style="{StaticResource TaskEditSeparator}" />

                            <!-- 截止日期 -->
                            <DockPanel>
                                <TextBlock Style="{StaticResource FieldLabel}" Text="截止日期" />
                                <DatePicker x:Name="EndDatePicker" HorizontalAlignment="Stretch" />
                            </DockPanel>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock Style="{StaticResource QuickFillLabel}" Text="快填" />
                                <WrapPanel>
                                    <ui:Button Content="今天" Tag="EndDate:Today" Padding="6,2" Margin="2,0,2,2" Click="OnDateQuickFill" />
                                    <ui:Button Content="明天" Tag="EndDate:Tomorrow" Padding="6,2" Margin="2,0,2,2" Click="OnDateQuickFill" />
                                    <ui:Button Content="后天" Tag="EndDate:DayAfter" Padding="6,2" Margin="2,0,2,2" Click="OnDateQuickFill" />
                                    <ui:Button Content="一周后" Tag="EndDate:Week" Padding="6,2" Margin="2,0,2,2" Click="OnDateQuickFill" />
                                    <ui:Button Content="一月后" Tag="EndDate:Month" Padding="6,2" Margin="2,0,2,2" Click="OnDateQuickFill" />
                                </WrapPanel>
                            </DockPanel>
                            <!-- 截止时间（时 : 分） -->
                            <DockPanel Margin="0,6,0,0">
                                <TextBlock Style="{StaticResource FieldLabel}" Text="截止时间" />
                                <StackPanel Orientation="Horizontal">
                                    <ComboBox x:Name="EndHourBox" Width="78" />
                                    <TextBlock Text=":" VerticalAlignment="Center" Margin="6,0,6,0" FontWeight="Bold" />
                                    <ComboBox x:Name="EndMinuteBox" Width="78" />
                                </StackPanel>
                            </DockPanel>
                            <DockPanel Margin="0,4,0,0">
                                <TextBlock Style="{StaticResource QuickFillLabel}" Text="快填" />
                                <WrapPanel>
                                    <ui:Button Content="现在" Tag="EndTime:Now" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                    <ui:Button Content="+0.5H" Tag="EndTime:H0.5" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                    <ui:Button Content="+1H" Tag="EndTime:H1" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                    <ui:Button Content="+2H" Tag="EndTime:H2" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                    <ui:Button Content="+8H" Tag="EndTime:H8" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                    <ui:Button Content="+12H" Tag="EndTime:H12" Padding="6,2" Margin="2,0,2,2" Click="OnTimeQuickFill" />
                                </WrapPanel>
                            </DockPanel>

                            <ui:Button x:Name="NewButton" Content="清空（新建）"
                                       HorizontalAlignment="Stretch" Height="30" Margin="0,14,0,0" Click="OnNew" />
                        </StackPanel>
                </TabItem>

                <!-- 关于 -->
                <TabItem Header="关于">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="4,8,8,4">
                        <StackPanel>
                            <TextBlock Text="Hope · 盼头" FontWeight="Bold" FontSize="18" Margin="0,4,0,2" />
                            <TextBlock x:Name="AboutVersionText" Text="v0.0.0"
                                       FontSize="14" Margin="0,0,0,12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                            <TextBlock TextWrapping="Wrap"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Text="桌面顶栏进度条 · 多任务多色 · 本地优先。" />
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Grid>
    </Grid>
</ui:FluentWindow>
